{
  "name": "infaqly",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n BE,FE,DB -c blue,green,yellow \"npm --prefix server run dev\" \"vite\" \"npm --prefix server run db:studio\"",
    "dev:fe": "vite",
    "dev:be": "npm --prefix server run dev",
    "build": "npm --prefix server run build && vite build",
    "start": "npm --prefix server run db:migrate && npm --prefix server run db:seed && node server/dist/index.js",
    "postinstall": "cd server && npm install",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "axios": "^1.15.0",
    "daisyui": "^4.12.24",
    "lucide-react": "^1.8.0",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  }
}
