{
  "name": "infaqly-server",
  "version": "1.0.0",
  "description": "infaqLy Backend API — Express.js + Drizzle ORM + PostgreSQL + Better Auth",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --require ./src/instrumentation.ts --ignore '.wa-session/**' src/index.ts",
    "build": "tsc",
    "start": "node --require ./dist/instrumentation.js dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.0",
    "sanitize-html": "^2.17.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.11.10",
    "@types/sanitize-html": "^2.16.1"
  }
}
